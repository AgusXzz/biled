{
  "name": "@whiskeysockets/baileys",
  "type": "module",
  "version": "7.0.0-rc13",
  "description": "A WebSockets library for interacting with WhatsApp Web",
  "keywords": [
    "whatsapp",
    "automation"
  ],
  "repository": {
    "url": "git@github.com:AgusXzz/biled.git"
  },
  "license": "MIT",
  "author": "AgusXzz",
  "main": "lib/index.js",
  "files": [
    "lib/**/*",
    "WAProto/**/*",
    "engine-requirements.js"
  ],
  "scripts": {
    "format": "prettier --write \"lib/**/*.js\"",
    "gen:protobuf": "sh WAProto/GenerateStatics.sh",
    "gen:proto-extract": "node proto-extract/index.js",
    "lint": "eslint lib",
    "lint:fix": "eslint lib --fix",
    "preinstall": "node ./engine-requirements.js"
  },
  "dependencies": {
    "@cacheable/node-cache": "^3.1.1",
    "@hapi/boom": "^10.0.1",
    "async-mutex": "^0.5.0",
    "libsignal": "^6.0.0",
    "lru-cache": "^11.5.2",
    "music-metadata": "^11.13.0",
    "p-queue": "^9.3.1",
    "pino": "^10.3",
    "protobufjs": "^8.7.0",
    "whatsapp-rust-bridge": "0.5.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "eslint": "^10",
    "jimp": "^1.6.1",
    "link-preview-js": "^4.0.4",
    "prettier": "^3.9.5",
    "protobufjs-cli": "^2.6.0"
  },
  "peerDependencies": {
    "audio-decode": "^2.1.3",
    "jimp": "^1.6.1",
    "link-preview-js": "^4.0.0",
    "sharp": "*"
  },
  "peerDependenciesMeta": {
    "audio-decode": {
      "optional": true
    },
    "jimp": {
      "optional": true
    },
    "link-preview-js": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
